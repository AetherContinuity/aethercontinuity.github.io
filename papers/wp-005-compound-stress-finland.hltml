<body>

<!-- DIH Header -->
<div class="dih">
  <div class="dih-left">
    <div class="dih-institute">Aether Continuity Institute · ACI</div>
    <div class="dih-series">Working Paper Series · <span class="series-accent">WP-005</span></div>
  </div>
