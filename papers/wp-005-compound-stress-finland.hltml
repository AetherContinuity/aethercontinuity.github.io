<title>ACI WP-005 — Compound Stress and Continuity Risk in Finland 2025–2035</title>
<link rel="preconnect" href="https://fonts.googleapis.com">
<link href="https://fonts.googleapis.com/css2?family=EB+Garamond:ital,wght@0,400;0,500;0,600;1,400;1,500&family=DM+Mono:wght@300;400&display=swap" rel="stylesheet">
<style>
  :root {
    --ink: #0e0d0b;
    --paper: #f5f0e8;
    --paper-2: #ede7d8;
    --paper-3: #e4dccb;
    --accent: #8b4513;
    --muted: #7a7468;
    --rule: #c8bfad;
    --serif: 'EB Garamond', Georgia, serif;
    --mono: 'DM Mono', 'Courier New', monospace;
  }

  *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
  html { font-size: 18px; scroll-behavior: smooth; }

  body {
    background-color: var(--paper);
    color: var(--ink);
    font-family: var(--serif);
    line-height: 1.75;
    min-height: 100vh;
    overflow-x: hidden;
  }

  body::before {
    content: '';
    position: fixed;
    inset: 0;
    background-image: url("data:image/svg+xml,%3Csvg viewBox='0 0 256 256' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='noise'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.9' numOctaves='4' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23noise)' opacity='0.04'/%3E%3C/svg%3E");
    pointer-events: none;
    z-index: 999;
    opacity: 0.5;
  }

  /* DIH Header */
  .dih {
    border-top: 2px solid var(--ink);
    border-bottom: 1px solid var(--rule);
    padding: 1.5rem 2rem 1.25rem;
    margin: 0 auto;
    max-width: 740px;
    display: grid;
    grid-template-columns: 1fr auto;
    gap: 1.5rem;
    align-items: start;
  }
  .dih-left { display: flex; flex-direction: column; gap: 0.2rem; }
  .dih-institute { font-family: var(--mono); font-size: 0.6rem; letter-spacing: 0.2em; text-transform: uppercase; color: var(--muted); }
  .dih-series { font-family: var(--mono); font-size: 0.72rem; letter-spacing: 0.1em; text-transform: uppercase; color: var(--ink); margin-top: 0.2rem; }
  .dih-series .series-accent { color: var(--accent); }
  .dih-right { display: flex; flex-direction: column; align-items: flex-end; gap: 0.2rem; }
  .dih-meta { font-family: var(--mono); font-size: 0.58rem; letter-spacing: 0.12em; text-transform: uppercase; color: var(--muted); line-height: 1.9; text-align: right; }
  .dih-meta strong { color: var(--ink); font-weight: 400; }
  .dih-status { display: inline-flex; align-items: center; gap: 0.4rem; border: 1px solid var(--rule); padding: 0.25rem 0.7rem; margin-top: 0.4rem; }
  .dih-status-dot { width: 4px; height: 4px; border-radius: 50%; background: #5a8a5a; }
  .dih-status-text { font-family: var(--mono); font-size: 0.55rem; letter-spacing: 0.15em; text-transform: uppercase; color: var(--muted); }

  /* Nav */
  nav {
    border-bottom: 1px solid var(--rule);
    padding: 1.4rem 4rem;
    display: flex;
    justify-content: space-between;
    align-items: center;
  }
