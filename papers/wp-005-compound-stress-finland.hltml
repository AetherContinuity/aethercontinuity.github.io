  .section-num { font-family: var(--mono); font-size: 0.72rem; letter-spacing: 0.12em; color: var(--accent); flex-shrink: 0; }
  h2.section-title { font-size: 1.3rem; font-weight: 500; letter-spacing: -0.01em; }

  .subsection { font-size: 1.05rem; font-weight: 600; margin: 1.75rem 0 0.75rem; }

  /* Callout */
  .callout { background: var(--paper-3); border-left: 3px solid var(--accent); padding: 1.25rem 1.5rem; margin: 1.75rem 0; }
