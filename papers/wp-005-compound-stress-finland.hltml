  /* Definition block */
  .definition-block { border: 1px solid var(--rule); padding: 1.5rem 1.75rem; margin: 1.75rem 0; background: var(--paper-2); }
  .definition-label { font-family: var(--mono); font-size: 0.58rem; letter-spacing: 0.2em; text-transform: uppercase; color: var(--muted); margin-bottom: 0.75rem; }
