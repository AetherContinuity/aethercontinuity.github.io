  /* Footer */
  footer { border-top: 1px solid var(--rule); padding: 2.5rem 4rem; display: grid; grid-template-columns: repeat(3, 1fr); gap: 2rem; font-family: var(--mono); font-size: 0.6rem; letter-spacing: 0.08em; color: var(--muted); line-height: 2; }

